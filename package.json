{
  "name": "desktop-test-app-electron",
  "version": "0.1.0",
  "description": "Electron companion to desktop-test-app for cua-sandbox MITM proxy integration tests",
  "main": "main.js",
  "author": {
    "name": "trycua",
    "email": "hello@trycua.com"
  },
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.trycua.desktop-test-app-electron",
    "productName": "desktop-test-app-electron",
    "linux": {
      "target": ["deb", "AppImage"],
      "category": "Utility"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": ["nsis", "portable"]
    },
    "deb": {
      "packageName": "desktop-test-app-electron",
      "depends": []
    },
    "files": [
      "main.js",
      "node_modules/**/*",
      "package.json"
    ],
    "asar": true
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/trycua/desktop-test-app-electron.git"
  }
}
